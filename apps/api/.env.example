# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: .env is gitignored — never commit real credentials.
# In production (ECS), these variables are set in the Task Definition.
# Sensitive values (DB_PASSWORD) come from AWS Secrets Manager.

# Runtime environment — affects logging verbosity and sync behavior
NODE_ENV=development

# Port the Express server listens on
PORT=3000

# PostgreSQL connection details
# When running via docker compose, DB_HOST is the service name "postgres"
# When running locally against a local PG instance, DB_HOST is "localhost"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=notes_db
DB_USER=postgres
DB_PASSWORD=postgres

# CORS — the frontend origin allowed to call this API
# Local development: Angular dev server
# Production: your web ALB DNS name (e.g. http://web-alb-123.us-east-1.elb.amazonaws.com)
CORS_ORIGIN=http://localhost:4200

# Injected by the GitHub Actions CI/CD pipeline at build time (--build-arg)
# The /version endpoint returns this value so you can verify which commit is deployed
# Leave as "local-dev" when running locally
GIT_COMMIT_SHA=local-dev
